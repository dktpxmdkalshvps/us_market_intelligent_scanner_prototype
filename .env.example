# Frontend (Vercel / local Next.js)
NEXT_PUBLIC_API_BASE_URL=https://quant-backend-e82y.onrender.com

# Backend (Render / local FastAPI)
APP_ENV=local
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://qs-front-psi.vercel.app,https://qsscreen.vercel.app
WEB_CONCURRENCY=2
PYTHON_VERSION=3.12.7
