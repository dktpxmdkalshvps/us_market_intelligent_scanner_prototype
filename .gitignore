# -----------------------------------------------------------------------------
# QuantScreen root .gitignore
# Applies to the whole portfolio monorepo, including frontend/ and backend/.
# Individual sub-project .gitignore files are kept as an additional safety layer.
# -----------------------------------------------------------------------------

# Secrets / environment variables
**/.env
**/.env.*
!**/.env.example
!**/.env.sample

# Node / Next.js / Vercel
**/node_modules/
**/.next/
**/out/
**/dist/
**/build/
**/.vercel/
**/.turbo/
**/coverage/
**/*.tsbuildinfo

# Python / FastAPI / Alembic runtime artifacts
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/.venv/
**/venv/
**/env/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/*.egg-info/

# Local databases and generated data
**/quantscreen.db
**/local.db
**/*.db
**/*.sqlite
**/*.sqlite3

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# OS / editor
.DS_Store
**/.DS_Store
**/.vscode/
**/.idea/
**/*.swp
**/*.swo

# Temporary archives / local exports
*.zip
*.tar
*.tar.gz
*.tgz
