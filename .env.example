# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Vercel Postgres / Supabase / Neon 모두 호환)
DATABASE_URL=postgresql://user:password@localhost:5432/quantscreen

# ── Cache ─────────────────────────────────────────────────────────────────────
# Redis URL (선택사항 – 없으면 자동으로 in-memory 캐시 사용)
REDIS_URL=redis://localhost:6379

# ── Frontend ──────────────────────────────────────────────────────────────────
# Vercel 배포 후 실제 URL로 교체
NEXT_PUBLIC_API_URL=/api

# ── Scheduler ─────────────────────────────────────────────────────────────────
# 미국 장 마감 후 데이터 갱신 시각 (America/New_York 기준)
SCHEDULER_HOUR=17
SCHEDULER_MINUTE=30

# ── Risk Filter ───────────────────────────────────────────────────────────────
RISK_MIN_PRICE=1.0
RISK_MIN_MARKET_CAP=50000000
